{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=eTracker;Trusted_Connection=True;Connection Timeout=30;"
  },
  "JwtSettings": {
    "SecretKey": "${JwtSettings__SecretKey}",
    "Issuer": "${JwtSettings__Issuer}",
    "Audience": "${JwtSettings__Audience}",
    "ExpirationHours": 24
  }
}
